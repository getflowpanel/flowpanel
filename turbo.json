{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".source/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test:unit": {
      "outputs": [".vitest-cache/**"]
    },
    "test:integration": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:chaos": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**"]
    },
    "typecheck": { "dependsOn": ["^build"] },
    "lint": { "outputs": [] }
  }
}
