{
  "name": "@flowpanel/adapter-prisma",
  "version": "0.0.0",
  "description": "Prisma ORM adapter for FlowPanel",
  "keywords": [
    "flowpanel",
    "prisma",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getflowpanel/flowpanel",
    "directory": "packages/adapter-prisma"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "pretest:unit": "prisma generate --schema=prisma/schema.prisma",
    "test:unit": "vitest run",
    "test:types": "tsd"
  },
  "tsd": {
    "directory": "types-test",
    "compilerOptions": {
      "moduleResolution": "node",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "paths": {
        "@flowpanel/adapter-prisma": [
          "./dist/index.d.ts"
        ]
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0 <7.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@flowpanel/core": "workspace:*"
  },
  "devDependencies": {
    "@prisma/client": "^5.20.0",
    "@types/node": "catalog:",
    "prisma": "^5.20.0",
    "tsd": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "^3.23.0"
  }
}
