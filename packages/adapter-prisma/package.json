{
  "name": "@flowpanel/adapter-prisma",
  "version": "0.1.0",
  "description": "Prisma adapter for FlowPanel",
  "keywords": [
    "flowpanel",
    "prisma",
    "adapter",
    "orm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/adapter-prisma"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0"
  },
  "dependencies": {
    "@flowpanel/core": "workspace:*",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0"
  }
}
