{
  "name": "@flowpanel/adapter-prisma",
  "version": "0.1.0",
  "description": "Prisma adapter for FlowPanel",
  "keywords": [
    "flowpanel",
    "prisma",
    "adapter",
    "orm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/adapter-prisma"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run src/__tests__/metadata.test.ts src/__tests__/filters.test.ts",
    "test:integration": "vitest run --project integration"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0 <7.0.0"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@flowpanel/core": "workspace:*",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
