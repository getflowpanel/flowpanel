{
  "name": "@flowpanel/react",
  "version": "1.0.1",
  "description": "Internal UI primitives for FlowPanel — shadcn-style components built on Radix + Tailwind v4 + design tokens",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Ch4m4/flowpanel",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
