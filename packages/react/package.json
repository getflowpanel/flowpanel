{
  "name": "@flowpanel/react",
  "version": "0.1.0",
  "description": "React components for FlowPanel pipeline dashboards",
  "keywords": [
    "flowpanel",
    "react",
    "dashboard",
    "admin",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Ch4m4/flowpanel",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./dist/theme/variables.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "./dist/theme/variables.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@flowpanel/core": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.0",
    "lucide-react": "^0.400.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/react": "^18.0.0"
  }
}
