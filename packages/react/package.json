{
  "name": "@flowpanel/react",
  "version": "0.1.0",
  "description": "React components for FlowPanel pipeline dashboards",
  "keywords": [
    "flowpanel",
    "react",
    "dashboard",
    "admin",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Ch4m4/flowpanel",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./dist/theme/variables.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "size-limit": "size-limit"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "./dist/theme/variables.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@flowpanel/core": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.400.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "jsdom": "^29.0.2",
    "size-limit": "^12.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "size-limit": [
    {
      "name": "FlowPanel React bundle (ESM)",
      "path": "dist/index.mjs",
      "limit": "70 kB",
      "gzip": true
    }
  ]
}
