  },
  "files": [
    "dist",
    "src/styles",
    "README.md"
  ],
  "dependencies": {
    "@conform-to/react": "^1.19.0",
    "@conform-to/zod": "^1.19.0",
    "@flowpanel/core": "workspace:*",
