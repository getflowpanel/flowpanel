{
	"name": "@flowpanel/react",
	"version": "0.1.0",
	"description": "React components for FlowPanel pipeline dashboards",
	"keywords": [
		"flowpanel",
		"react",
		"dashboard",
		"admin",
		"ui"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Ch4m4/flowpanel",
		"directory": "packages/react"
	},
	"homepage": "https://github.com/Ch4m4/flowpanel",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		},
		"./theme.css": "./dist/theme/variables.css"
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit"
	},
	"sideEffects": [
		"./dist/theme/variables.css"
	],
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"dependencies": {
		"@flowpanel/core": "workspace:*",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"@tanstack/react-query": "^5.0.0"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"@types/react": "^18.0.0"
	}
}
