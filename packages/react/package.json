{
  "name": "@flowpanel/react",
  "version": "0.1.0",
  "description": "React UI components for FlowPanel admin dashboard",
  "keywords": [
    "flowpanel",
    "admin",
    "pipeline",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/react"
  },
  "license": "MIT",
  "homepage": "https://flowpanel.dev",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./dist/theme/variables.css",
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "size-limit": "size-limit"
  },
  "sideEffects": [
    "./dist/theme/variables.css",
    "./dist/styles.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@flowpanel/core": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "35 kB"
    }
  ]
}
