{
  "name": "@flowpanel/locale-ru",
  "version": "0.1.0",
  "description": "Russian locale for FlowPanel UI",
  "keywords": [
    "flowpanel",
    "admin",
    "pipeline",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/locale-ru"
  },
  "license": "MIT",
  "homepage": "https://flowpanel.dev",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
