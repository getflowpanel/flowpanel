{
  "name": "@flowpanel/queue-bullmq",
  "version": "0.1.0",
  "description": "BullMQ queue adapter for FlowPanel",
  "keywords": [
    "flowpanel",
    "bullmq",
    "queue",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/queue-bullmq"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "bullmq": ">=4.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@flowpanel/core": "workspace:*"
  },
  "devDependencies": {
    "bullmq": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
