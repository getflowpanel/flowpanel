{
  "name": "@flowpanel/cli",
  "version": "0.1.0",
  "description": "CLI tools for FlowPanel — init, scaffold, doctor",
  "keywords": [
    "flowpanel",
    "cli",
    "pipeline",
    "admin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/cli"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "flowpanel": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@flowpanel/core": "workspace:*",
    "commander": "^12.0.0",
    "kleur": "^4.1.5",
    "picocolors": "^1.1.1"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
