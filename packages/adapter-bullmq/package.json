{
  "name": "@flowpanel/adapter-bullmq",
  "version": "0.0.0",
  "description": "BullMQ queue UIs for FlowPanel via bull-board",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
