{
  "name": "@flowpanel/core",
  "version": "0.1.0-alpha.0",
  "description": "Core logic for FlowPanel — types, defineAdmin, runtime helpers",
  "keywords": [
    "flowpanel",
    "admin",
    "nextjs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Ch4m4/flowpanel",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^3.23.0"
  }
}
