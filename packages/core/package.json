{
  "name": "@flowpanel/core",
  "version": "0.1.0",
  "description": "Core logic for FlowPanel pipeline dashboards",
  "keywords": [
    "flowpanel",
    "admin",
    "pipeline",
    "dashboard",
    "trpc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Ch4m4/flowpanel",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./trpc": {
      "types": "./dist/trpc/index.d.ts",
      "import": "./dist/trpc/index.mjs",
      "require": "./dist/trpc/index.cjs"
    },
    "./package.json": "./package.json",
    "./migrations/*": "./migrations/*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "migrations",
    "package.json",
    "README.md"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@trpc/server": "^11.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
