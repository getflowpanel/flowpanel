{
  "name": "@flowpanel/core",
  "version": "1.0.0-beta.2",
  "description": "Core logic for FlowPanel — types, defineAdmin, runtime helpers",
  "keywords": [
    "flowpanel",
    "admin",
    "nextjs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Ch4m4/flowpanel",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./labels": {
      "types": "./dist/labels.d.ts",
      "import": "./dist/labels.mjs",
      "require": "./dist/labels.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:types": "tsd"
  },
  "tsd": {
    "directory": "types-test",
    "compilerOptions": {
      "moduleResolution": "node",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "paths": {
        "@flowpanel/core": [
          "./dist/index.d.ts"
        ],
        "@flowpanel/core/labels": [
          "./dist/labels.d.ts"
        ]
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "ioredis": "^5.10.1",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "expect-type": "^0.20.0",
    "react": "^19.2.5",
    "tsd": "^0.33.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^3.23.0"
  }
}
