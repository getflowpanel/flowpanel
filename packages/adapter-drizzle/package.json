{
  "name": "@flowpanel/adapter-drizzle",
  "version": "0.0.0",
  "description": "Drizzle ORM adapter for FlowPanel",
  "keywords": [
    "flowpanel",
    "drizzle",
    "adapter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ch4m4/flowpanel",
    "directory": "packages/adapter-drizzle"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:types": "tsd"
  },
  "tsd": {
    "directory": "types-test",
    "compilerOptions": {
      "moduleResolution": "node",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "paths": {
        "@flowpanel/adapter-drizzle": [
          "./dist/index.d.ts"
        ]
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0 <1.0.0",
    "zod": "^3.23.0"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@flowpanel/core": "workspace:*",
    "drizzle-zod": "^0.5.0"
  },
  "devDependencies": {
    "@testcontainers/mysql": "^11.14.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.0",
    "mysql2": "^3.22.2",
    "pg": "^8.11.0",
    "postgres": "^3.4.0",
    "testcontainers": "^10.0.0",
    "tsd": "^0.33.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "zod": "^3.23.0"
  }
}
