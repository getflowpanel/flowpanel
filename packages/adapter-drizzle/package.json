    "drizzle-orm": ">=0.30.0"
  },
  "dependencies": {
    "@flowpanel/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
