# Local dev defaults match docker-compose.yml. For a hosted demo,
# fill these with your provider's values and DO NOT commit the .env.
DATABASE_URL=postgres://fp:fp@localhost:54329/freelance_radar

# Turn the admin into a public read-only demo. When "true":
# - row actions are disabled with a tooltip
# - create/update/delete are gated off on every resource
# - a banner is rendered above the host header
DEMO_MODE=false

# Optional. When set, the admin shows live queue health metrics and
# `pnpm flowpanel:board` exposes bull-board on :3001.
# REDIS_URL=redis://localhost:6379
